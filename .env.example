# Copy this file to .env and fill in your values.
# On Railway / Render, set these in the platform dashboard instead.

# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-here

# SQLite database file path.
# Locally: leave blank (defaults to ./aureon.db next to server.js).
# Railway: set to /data/aureon.db and mount a volume at /data.
# DATABASE_PATH=/data/aureon.db

# ── ETF live data (optional but strongly recommended) ──────────────────────────
# Get a free API key at https://www.coinglass.com/pricing
# Without this, ETF data is served from the committed latest-etf-data.json file
# and will grow stale between manual updates.
# COINGLASS_API_KEY=your-key-here

# Alternative: point to any URL that returns a valid Aureon ETF payload JSON.
# ETF_DATA_URL=https://example.com/my-etf-data.json

# Port (optional — defaults to 8080)
# PORT=8080
